{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_mcps": [
    "context7"
  ],
  "disabled_agents": [
    "oracle",
    "librarian"
  ],
  "disabled_skills": [
    "playwright"
  ],
  "disabled_hooks": [
    "auto-update-checker",
    "startup-toast"
  ],
  "disabled_commands": [
    "init-deep"
  ],
  "disabled_tools": [
    "mcp_bash"
  ],
  "_migrations": [
    "v1_to_v2"
  ],
  "hashline_edit": true,
  "new_task_system_enabled": true,
  "default_run_agent": "build",
  "agent_order": [
    "sisyphus",
    "hephaestus",
    "oracle"
  ],
  "agents": {
    "build": {
      "model": "claude-sonnet-4-20250514",
      "fallback_models": [
        "claude-haiku",
        "gpt-4o"
      ],
      "variant": "fast",
      "category": "general",
      "skills": [
        "git-master"
      ],
      "temperature": 0.7,
      "top_p": 0.9,
      "prompt": "You are a helpful coding assistant.",
      "prompt_append": "Always verify your work.",
      "tools": {
        "bash": true,
        "webfetch": false
      },
      "disable": false,
      "description": "Main build agent",
      "mode": "primary",
      "color": "#FF5733",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "ask",
        "doom_loop": "deny",
        "external_directory": "ask"
      },
      "maxTokens": 8192,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 4096
      },
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "providerOptions": {
        "custom_option": true
      },
      "ultrawork": {
        "model": "claude-sonnet-4-20250514",
        "variant": "fast"
      }
    },
    "plan": {
      "model": "o3",
      "fallback_models": "gpt-4o-mini",
      "category": "planning",
      "permission": {
        "bash": {
          "git": "allow",
          "npm": "ask",
          "rm": "deny"
        }
      }
    }
  },
  "categories": {
    "general": {
      "model": "claude-sonnet-4-20250514",
      "fallback_models": [
        "claude-haiku"
      ],
      "variant": "balanced",
      "temperature": 0.5,
      "top_p": 0.95,
      "maxTokens": 8192,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 4096
      },
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "tools": {
        "edit": true,
        "bash": true
      },
      "prompt_append": "Be concise.",
      "description": "General purpose category for most tasks"
    },
    "planning": {
      "model": "o3",
      "thinking": {
        "type": "enabled"
      }
    }
  },
  "claude_code": {
    "mcp": true,
    "commands": true,
    "skills": true,
    "agents": true,
    "hooks": true,
    "plugins": false,
    "plugins_override": {
      "context7": true
    }
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": false
  },
  "comment_checker": {
    "custom_prompt": "Check for TODO comments."
  },
  "experimental": {
    "aggressive_truncation": true,
    "truncate_all_tool_outputs": false,
    "hashline_edit": true,
    "disable_omo_env": true,
    "model_fallback_title": false,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "turn_protection": {
        "enabled": true,
        "turns": 5
      },
      "protected_tools": [
        "task",
        "todowrite"
      ],
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 10
        }
      }
    },
    "disable_live_parent_wake_routing": false
  },
  "auto_update": true,
  "skills": [
    "git-master",
    "playwright"
  ],
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 50,
    "state_dir": "/tmp/ralph",
    "default_strategy": "continue"
  },
  "runtime_fallback": {
    "enabled": true,
    "max_fallback_attempts": 3,
    "cooldown_seconds": 30
  },
  "background_task": {
    "defaultConcurrency": 4,
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 5
    },
    "modelConcurrency": {
      "claude-sonnet-4": 2
    },
    "staleTimeoutMs": 300000,
    "messageStalenessTimeoutMs": 120000
  },
  "browser_automation_engine": {
    "provider": "playwright"
  },
  "websearch": {
    "provider": "perplexity"
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 80,
    "agent_pane_min_width": 40
  },
  "notification": {
    "force_enable": true
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "openclaw": {
    "enabled": true,
    "gateways": {
      "discord": {
        "type": "http",
        "url": "https://discord.example.com/webhook",
        "method": "POST",
        "headers": {
          "Authorization": "Bot token123"
        },
        "timeout": 5000
      }
    },
    "hooks": {
      "on_complete": {
        "enabled": true,
        "gateway": "discord",
        "instruction": "Notify on task completion"
      }
    },
    "replyListener": {
      "discordBotToken": "token123",
      "discordChannelId": "123456",
      "discordMention": "<@bot>",
      "authorizedDiscordUserIds": [
        "user1"
      ],
      "telegramBotToken": "tg-token",
      "telegramChatId": "chat123",
      "pollIntervalMs": 3000,
      "rateLimitPerMinute": 10,
      "maxMessageLength": 500,
      "includePrefix": true
    }
  },
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": false,
    "refresh_timeout_ms": 30000,
    "source_url": "https://models.dev/api/models"
  },
  "keyword_detector": {
    "disabled_keywords": [
      "ultrawork",
      "hyperplan-ultrawork"
    ]
  },
  "team_mode": {
    "enabled": true,
    "tmux_visualization": false,
    "max_parallel_members": 4,
    "max_members": 8,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "base_dir": "/tmp/team-mode",
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },
  "monitor": {
    "enabled": false,
    "live_mode_enabled": false,
    "allowed_commands": [
      "ls",
      "git status"
    ],
    "max_monitors_per_session": 3,
    "max_runtime_ms": 1800000,
    "batch_max_lines": 50,
    "batch_max_bytes": 16384,
    "flush_interval_ms": 1000,
    "ring_max_lines": 1000,
    "line_max_bytes": 8192,
    "pattern_max_length": 512
  },
  "codegraph": {
    "auto_provision": true,
    "enabled": true,
    "install_dir": "/opt/codegraph",
    "telemetry": false,
    "watch_debounce_ms": 300
  },
  "tui": {
    "sidebar": {
      "enabled": true
    }
  }
}
